---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { css } from 'styled-system/css';
import { hstack, vstack } from 'styled-system/patterns';
import Github from "@/assets/brand-github.svg"
import ArrowUpRight from "@/assets/arrow-up-right.svg"
import {Button} from "@/lib/components/ui/button"

interface Props {
  title: string;
  summary: string;
}

const { title, summary} = Astro.props
---
<header class={vstack({
  justifyContent: "center",
  gap: "6",
  py: { mdDown: "16", md: "36"},
  w: { mdDown: "full", md: "2xl"}
})}>
    <h1 class={css({
      textStyle: { mdDown: "xl", md: "2xl"},
      fontWeight: "bold",
      w: "full"
    })}>{title}</h1>
    <p class={css({
      color: "fg.muted",
      fontSize: { mdDown: "lg", md: "xl" }
    })}>{summary}</p>

    <div class={hstack({ gap: "4", justify: "start", w: "full"})}>
        <Button href={getRelativeLocaleUrl(Astro.currentLocale!, "/contact")}>Get in touch <ArrowUpRight /></Button>
        <Button href="https://github.com/agashane" target="_blank">
            <Github />
        </Button>
    </div>
</header>
